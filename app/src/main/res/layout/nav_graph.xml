<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/historySymptomsFragment">

    <fragment
        android:id="@+id/historySymptomsFragment"
        android:name="com.example.meditrack.fragments.HistorySymptomsFragment"
        android:label="Symptom History"
        tools:layout="@layout/fragment_history_symptoms">

        <action
            android:id="@+id/action_historySymptoms_to_addSymptom"
            app:destination="@id/addSymptomFragment" />
    </fragment>

    <fragment
        android:id="@+id/addSymptomFragment"
        android:name="com.example.meditrack.fragments.AddSymptomFragment"
        android:label="Add Symptom"
        tools:layout="@layout/fragment_add_symptom" />

</navigation>