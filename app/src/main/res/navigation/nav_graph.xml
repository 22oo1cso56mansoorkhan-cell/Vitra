<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.meditrack.fragments.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/medicineFragment"
        android:name="com.example.meditrack.fragments.MedicineFragment"
        android:label="Medicines"
        tools:layout="@layout/fragment_medicines" />

    <fragment
        android:id="@+id/vitalsFragment"
        android:name="com.example.meditrack.fragments.VitalsFragment"
        android:label="Vitals"
        tools:layout="@layout/fragment_vitals" />

    <fragment
        android:id="@+id/historyDoctorFragment"
        android:name="com.example.meditrack.fragments.HistoryDoctorFragment"
        android:label="Doctor Visits"
        tools:layout="@layout/fragment_history_doctor">

        <action
            android:id="@+id/action_historyDoctorFragment_to_addDoctorVisitFragment"
            app:destination="@id/addDoctorVisitFragment" />

    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.meditrack.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/addDoctorVisitFragment"
        android:name="com.example.meditrack.fragments.AddDoctorVisitFragment"
        android:label="Add Doctor Visit"
        tools:layout="@layout/fragment_add_doctor_visit" />

</navigation>